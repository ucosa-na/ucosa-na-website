NODE_ENV=development
PORT=3000
JWT_SECRET=change-this-to-a-long-random-string

# PostgreSQL — update credentials to match your postgres container/server
DATABASE_URL=postgresql://ucosa:your_db_password@ucosa-postgres:5432/ucosa

# These must match DATABASE_URL credentials (used to start the postgres container)
POSTGRES_DB=ucosa
POSTGRES_USER=ucosa
POSTGRES_PASSWORD=your_db_password

# SendGrid — for welcome emails
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_USER=ucosa.northamerica@gmail.com

# Seed admin (run: node src/seed-admin.js)
ADMIN_EMAIL=ucosa.northamerica@gmail.com
ADMIN_INIT_PASSWORD=Admin@ucosa2026
